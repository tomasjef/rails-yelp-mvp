<%= simple_form_for(@restaurant) do |f| %>
  <%= f.input :name %>
  <%= f.input :address %>
  <%= f.input :phone_number %>
  <%= f.input :category, collection: Restaurant::CATEGORIES, input_html: { class: "form-select form-select-sm w-auto" } %>
  <%= f.submit class: "btn btn-success mt-2"%>
<% end %>
